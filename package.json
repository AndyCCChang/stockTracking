{
  "name": "stock-tracking",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix server run build && npm --prefix client run build",
    "lint": "npm --prefix server run lint && npm --prefix client run lint",
    "db:init": "npm --prefix server run db:init",
    "db:seed": "npm --prefix server run db:seed",
    "test:server": "npm --prefix server run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2"
  }
}
