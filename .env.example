# Server
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/stock_tracking
JWT_SECRET=replace-with-a-long-random-secret
PORT=4000
# In production, set PORT to the value required by your host, for example 10000 on Render.
CORS_ORIGIN=http://localhost:5173
# Multiple origins can be provided as a comma-separated list.

# Client
VITE_API_URL=http://localhost:4000/api

# Price provider selection: auto, finnhub, alphavantage, mock
PRICE_PROVIDER=auto

# Optional real-time provider keys
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
